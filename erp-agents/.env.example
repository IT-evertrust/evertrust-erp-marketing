# erp-agents configuration. Copy to .env and fill in. Names mirror settings.py; several
# fields also accept the legacy names already used in the team .env (aliases in parentheses).

AGENT_MODE=dry_run
AGENT_PORT=8001
LOG_LEVEL=info

# ---- ERP backend (machine API) ----
ERP_API_URL=http://localhost:3001          # (or ERP_BASE_URL)
ERP_AGENT_TOKEN=                            # (or ARSENAL_TOKEN) — must equal the ERP's ARSENAL_INGEST_TOKEN

# ---- LLM: local Hermes via the LiteLLM gateway (OpenAI-compatible /v1) ----
LLM_PROVIDER=hermes
LLM_BASE_URL=https://mac-mini-ca-mac.tailc3d837.ts.net/v1   # (or LITELLM_BASE_URL)
LLM_API_KEY=                                # (or LITELLM_API_KEY) — the n8n virtual key
LLM_MODEL=hermes                            # (or OPENAI_MODEL)

# ---- Google (Gmail / Calendar / Docs) — only needed for live side-effects ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_USER_ID=me
GOOGLE_CALENDAR_ID=primary                  # (or SALES_CALENDAR_ID)
GOOGLE_DOCS_PARENT_FOLDER_ID=

# ---- WhatsApp Cloud API — only needed for live manager notifications ----
WHATSAPP_API_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=                   # (or SENDER_PHONE_NUMBER_ID)
WHATSAPP_ACCESS_TOKEN=                      # (or WHATSAPP_API_KEY)

# ---- Read AI — meeting transcripts (activate stage, later) ----
READ_AI_API_KEY=
READ_AI_BASE_URL=

# ---- Search — lead discovery (reach stage, later) ----
SEARCH_PROVIDER=serper
SEARCH_API_KEY=
