# Copy to .env in this directory and fill in. .env is gitignored — NEVER commit it.
# Shared team values (the Mac mini's stack) live in the team password vault.
#
# Generate secrets:
#   openssl rand -base64 24    # passwords
#   openssl rand -base64 32    # N8N_ENCRYPTION_KEY

# ── Host identity ──────────────────────────────────────────────────────
# Hostname clients use to reach this stack; feeds n8n webhook/editor URLs.
#   Laptop running its own local stack:  localhost
#   Mac mini (shared stack):             mac-mini-ca-mac.tailc3d837.ts.net
HOST_NAME=localhost

# ── ERP PostgreSQL (published on 5432) ─────────────────────────────────
DB_USER=evertrust-erp
DB_PASSWORD=                        # REQUIRED
DB_NAME=postgres

# ── App-side connection (NestJS reads DB_*; Prisma will read DATABASE_URL)
# Point DB_HOST at the mini to use the shared Postgres. Use your own
# per-developer database (erp_<yourname>) — see docs/team-hosting.md.
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://evertrust-erp:CHANGE_ME@localhost:5432/postgres
LOG_LEVEL=debug

# ── App secrets / config (not all wired up in code yet) ────────────────
JWT_SECRET=
CORS_ORIGIN=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── n8n PostgreSQL (loopback-only on 5433) ─────────────────────────────
N8N_DB_USER=n8n
N8N_DB_PASSWORD=                    # REQUIRED
N8N_DB_NAME=n8n

# ── n8n ────────────────────────────────────────────────────────────────
# REQUIRED — encrypts all credentials stored in n8n.
# NEVER change after first boot: stored credentials become undecryptable.
N8N_ENCRYPTION_KEY=
N8N_PORT=5678
GENERIC_TIMEZONE=Europe/Berlin

# ── pgAdmin (optional; only with: docker compose --profile tools up -d pgadmin)
PGADMIN_EMAIL=admin@erp.com
PGADMIN_PASSWORD=                   # required only when the tools profile is used
