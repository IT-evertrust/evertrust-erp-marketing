# Copy to .env in this directory and fill in. .env is gitignored — NEVER commit it.
# Shared team values live in the team password vault.
#
# Generate secrets:  openssl rand -base64 24

# ── ERP PostgreSQL container (published on 5432) ───────────────────────
DB_USER=evertrust-erp
DB_PASSWORD=                        # REQUIRED (compose fails fast without it)
DB_NAME=postgres
# Fresh-volume bootstrap only (postgres-init/01-init-dbs.sh): creates the
# litellm role/DB for the ai-stack. Same value as LITELLM_DB_PASSWORD in
# ai-stack/.env. Ignored on an already-initialized volume.
LITELLM_DB_PASSWORD=

# ── API (NestJS) — validated at boot by src/config/env.schema.ts ───────
# From the erp-api CONTAINER the host is `erp-postgres` (compose DNS).
# From a LAPTOP use the mini's Tailscale name and your per-dev database
# (erp_<yourname>) — see docs/team-hosting.md. Production DB is `evertrust`.
DATABASE_URL=postgresql://evertrust-erp:CHANGE_ME@erp-postgres:5432/evertrust
JWT_SECRET=                         # REQUIRED
JWT_EXPIRES_IN=7d
# NODE_ENV, PORT (3001) and UPLOAD_DIR are set by docker-compose for the container;
# schema defaults cover laptop dev (PORT 3001, UPLOAD_DIR ./uploads).

# Comma-separated browser origins allowed by CORS. Empty = no CORS.
CORS_ORIGINS=http://mac-mini-ca-mac.tailc3d837.ts.net:3000,http://localhost:3000

# Cookies: web (:3000) and API (:3001) share the tailnet hostname → same-site,
# so lax works. Plain HTTP on the tailnet (WireGuard-encrypted) → secure=false.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# DEMO / NO-LOGIN MODE — dev/demo only, NEVER true on the mini (it makes all
# org data reachable by anyone who can hit the API).
AUTH_DISABLED=false
AUTH_DISABLED_USER_EMAIL=

# One-shot opt-in to run the dev seed on an EMPTY production DB (plants a
# SUPER_ADMIN with a known dev password — api-start.sh skips it in production
# otherwise). Set true for one boot, change the admin password, remove it.
# SEED_DEV_USERS=true

# ── n8n cloud (evertrustgmbh.app.n8n.cloud) ────────────────────────────
# Arsenal / Growth Engine trigger webhooks. Blank = that trigger is disabled.
N8N_AIM_WEBHOOK_URL=
N8N_CAMPAIGNS_LIST_WEBHOOK_URL=
N8N_LEAD_SATELLITE_WEBHOOK_URL=
N8N_AMMO_FORGE_WEBHOOK_URL=
N8N_REACH_BAZOOKA_WEBHOOK_URL=
N8N_REPLY_GLOCK_WEBHOOK_URL=
N8N_SLEEPER_GRENADE_WEBHOOK_URL=
N8N_HERMES_RFQ_WEBHOOK_URL=
N8N_PROVISION_HOT_LEADS_WEBHOOK_URL=
N8N_HOT_LEADS_PIPELINE_WEBHOOK_URL=
# RAG Draft Review overrides; blank falls back to ${N8N_API_URL}/webhook/…
N8N_RAG_DRAFTS_WEBHOOK_URL=
N8N_RAG_SEND_WEBHOOK_URL=
N8N_RAG_SCAN_WEBHOOK_URL=

# n8n public API (read-only executions poller). Blank either = feature off.
N8N_API_URL=
N8N_API_KEY=

# n8n → ERP run-callback shared secret (x-arsenal-token header on the public
# POST /arsenal/runs/callback route). Blank = callback endpoint disabled.
ARSENAL_INGEST_TOKEN=

# ── Claude price-assist (Phase 5b) ─────────────────────────────────────
# Blank key = feature disabled (endpoint returns { configured: false }).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── Web (erp-web build arg — INLINED at image build time) ──────────────
NEXT_PUBLIC_API_URL=http://mac-mini-ca-mac.tailc3d837.ts.net:3001
