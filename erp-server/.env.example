# Copy to .env in this directory and fill in. .env is gitignored — NEVER commit it.
# Shared team values live in the team password vault.
#
# Generate secrets:  openssl rand -base64 24

# ── ERP PostgreSQL (published on 5432) ─────────────────────────────────
DB_USER=evertrust-erp
DB_PASSWORD=                        # REQUIRED
DB_NAME=postgres

# ── App-side connection (NestJS reads DB_*; Prisma will read DATABASE_URL)
# DB_HOST: localhost on the Mac mini itself; the mini's Tailscale name from laptops.
# Use your own per-developer database (erp_<yourname>) — see docs/team-hosting.md.
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://evertrust-erp:CHANGE_ME@localhost:5432/postgres
LOG_LEVEL=debug

# ── App secrets / config (not all wired up in code yet) ────────────────
JWT_SECRET=
CORS_ORIGIN=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000
