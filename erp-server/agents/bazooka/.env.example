# Copy to .env and fill in. Only DATABASE_URL is needed for an isolated dry run.

# --- required (all modes) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bazooka

# --- LLM validation (skip with --no-llm) ---
LITELLM_BASE_URL=http://<mac-mini>:4000/v1
LITELLM_API_KEY=sk-anything
LLM_MODEL=deepseek

# --- live mode only ---
WHATSAPP_PROVIDER=meta            # 'meta' or '360dialog'
WHATSAPP_API_KEY=
MANAGER_WHATSAPP_NUMBER=84333634500
SENDER_PHONE_NUMBER_ID=1030239273516528
# Gmail: put client_secret.json in this folder, then run
#   python -m bazooka.auth info   and   python -m bazooka.auth hanna
