# Origin of the NestJS API. Inlined into the client bundle at build time
# (NEXT_PUBLIC_*). Override per environment; defaults to local dev if unset.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Google OAuth 2.0 Web client ID for "Sign in with Google" (the only login method).
# Inlined into the client bundle at build time (NEXT_PUBLIC_*). Must match the
# GOOGLE_CLIENT_ID configured on the API (it verifies the ID token's audience).
# When blank the login page shows a "not configured" notice and hides the button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
