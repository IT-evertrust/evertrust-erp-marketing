# Copy to .env in this directory (chmod 600). .env is gitignored — NEVER commit it.
# Canonical copies of all values live in the team password vault.
#
# Generate:
#   openssl rand -hex 24      # LITELLM_MASTER_KEY (prefix with sk-), LITELLM_DB_PASSWORD, QDRANT_API_KEY
#   openssl rand -base64 32   # LITELLM_SALT_KEY

# Admin key for the gateway (NOT the key n8n uses — n8n gets a minted virtual key)
LITELLM_MASTER_KEY=sk-CHANGE_ME

# Encrypts credentials at rest in the litellm DB. Set once, NEVER change afterwards.
LITELLM_SALT_KEY=

# Password for the 'litellm' role on the existing erp-postgres (database 'litellm')
LITELLM_DB_PASSWORD=

# Qdrant API key — n8n's Qdrant credential uses this too
QDRANT_API_KEY=

# Trev's Ollama on the tailnet — the PRIMARY model host (http://100.x.y.z:11434).
# Until Trev's machine is onboarded, point this at the mini's own Ollama:
# TAILNET_OLLAMA=http://host.docker.internal:11434
TAILNET_OLLAMA=http://host.docker.internal:11434

# SearXNG cookie/session secret (openssl rand -hex 32). Internal to the container.
SEARXNG_SECRET=

# Key the searxng-auth proxy requires in the X-Search-Key header (openssl rand -hex 24).
# n8n's "SearXNG (mac-mini)" Header Auth credential uses this value.
SEARXNG_API_KEY=
